# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and should NEVER be committed.

# Set to 'true' to show demo credentials panel on the login page (dev only)
VITE_SHOW_DEMO_CREDENTIALS=false

# Demo credential values (only used when VITE_SHOW_DEMO_CREDENTIALS=true)
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASS=
VITE_DEMO_STUDENT_EMAIL=
VITE_DEMO_STUDENT_PASS=
VITE_DEMO_CONTRIB_EMAIL=
VITE_DEMO_CONTRIB_PASS=
