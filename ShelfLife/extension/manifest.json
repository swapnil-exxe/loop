{
  "manifest_version": 3,
  "name": "ShelfLife",
  "version": "1.0",
  "description": "Save any website instantly to your ShelfLife dashboard.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["content.js"]
    }
  ]
}
